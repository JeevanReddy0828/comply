# ml-service configuration. Copy to .env and adjust.

# Guard
GUARD_MODEL=protectai/deberta-v3-base-prompt-injection-v2
GUARD_INJECTION_LABEL=INJECTION
GUARD_BLOCK_THRESHOLD=0.8
GUARD_FLAG_THRESHOLD=0.5
ENABLE_CLASSIFIER=true

# Rate limiting (per identifier)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60

# Comply core API — used to emit guard events as evidence (Phase 2)
COMPLY_API_URL=http://localhost:8000

# RAG generation (Phases 4-5) — local retrieval, hosted answer
ANTHROPIC_API_KEY=
RAG_ANSWER_MODEL=claude-sonnet-4-5
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CORS (frontend dev origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
