# Comply backend configuration. Copy to .env and adjust.

# Postgres — matches docker-compose.yml defaults
DATABASE_URL=postgresql+psycopg://comply:comply@localhost:5432/comply

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Catalog content (version-controlled regulatory YAML)
CATALOG_DIR=../compliance

# CORS (frontend dev origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
